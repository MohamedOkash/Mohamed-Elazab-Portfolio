rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == "admin@az.com"
                   && request.resource.size <= 5242880
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
